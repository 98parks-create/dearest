{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/toss-api/:path*",
      "destination": "https://js.tosspayments.com/:path*"
    },
    {
      "source": "/((?!api/|.*\\.[a-z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}
